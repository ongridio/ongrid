# syntax=docker/dockerfile:1.7
# ongrid-edge agent image — runs on user hosts, dials out to cloud tunnel.
# Build context MUST be the repo root (see Makefile target `docker-ongrid-edge`).
#
# NOTE on ports:
#   The edge agent does NOT accept inbound traffic in normal operation — it
#   dials the cloud tunnel (TUNNEL_ADDR) as a client. The EXPOSE 9101 below is
#   ONLY for the agent's own local /metrics endpoint, useful for local debug
#   (e.g. `curl localhost:9101/metrics`). Production deployments can ignore it.

ARG VERSION=dev
ARG PROMTAIL_VERSION=3.4.0
ARG NODE_EXPORTER_VERSION=1.8.2
ARG PROCESS_EXPORTER_VERSION=0.8.4
ARG OTELCOL_VERSION=0.118.0

# ---------- Stage 1: builder ----------
FROM golang:1.25-alpine AS builder

ARG VERSION
ARG TARGETARCH
ARG GOPROXY=https://proxy.golang.org,direct
ENV GOPROXY=${GOPROXY}
WORKDIR /app

COPY go.mod go.sum ./
RUN --mount=type=cache,target=/go/pkg/mod \
    go mod download

COPY . .

RUN --mount=type=cache,target=/go/pkg/mod \
    --mount=type=cache,target=/root/.cache/go-build \
    CGO_ENABLED=0 GOOS=linux GOARCH="${TARGETARCH:-$(go env GOARCH)}" \
    go build -trimpath \
    -ldflags="-s -w -X main.version=${VERSION}" \
    -o /out/ongrid-edge ./cmd/ongrid-edge

# ---------- Stage 2: bundled logs plugin ----------
FROM alpine:3.20 AS promtail

ARG PROMTAIL_VERSION
ARG TARGETARCH
RUN set -eux; \
    apk add --no-cache ca-certificates curl unzip; \
    arch="${TARGETARCH:-$(apk --print-arch)}"; \
    case "$arch" in \
        x86_64) arch=amd64 ;; \
        aarch64) arch=arm64 ;; \
        amd64|arm64) ;; \
        *) echo "unsupported promtail arch: $arch" >&2; exit 1 ;; \
    esac; \
    mkdir -p /out; \
    asset="promtail-linux-${arch}.zip"; \
    base="https://github.com/grafana/loki/releases/download/v${PROMTAIL_VERSION}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/promtail.zip "${base}/${asset}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/SHA256SUMS "${base}/SHA256SUMS"; \
    awk -v asset="${asset}" '$2 == asset { print $1 "  /tmp/promtail.zip" }' /tmp/SHA256SUMS | sha256sum -c -; \
    unzip -p /tmp/promtail.zip > /out/promtail; \
    chmod 0755 /out/promtail; \
    rm -f /tmp/promtail.zip

# ---------- Stage 3: bundled host metrics plugin ----------
FROM alpine:3.20 AS node-exporter

ARG NODE_EXPORTER_VERSION
ARG TARGETARCH
RUN set -eux; \
    apk add --no-cache ca-certificates curl tar; \
    arch="${TARGETARCH:-$(apk --print-arch)}"; \
    case "$arch" in \
        x86_64) arch=amd64 ;; \
        aarch64) arch=arm64 ;; \
        amd64|arm64) ;; \
        *) echo "unsupported node_exporter arch: $arch" >&2; exit 1 ;; \
    esac; \
    mkdir -p /out; \
    asset="node_exporter-${NODE_EXPORTER_VERSION}.linux-${arch}.tar.gz"; \
    base="https://github.com/prometheus/node_exporter/releases/download/v${NODE_EXPORTER_VERSION}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/node_exporter.tgz "${base}/${asset}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/sha256sums.txt "${base}/sha256sums.txt"; \
    awk -v asset="${asset}" '$2 == asset { print $1 "  /tmp/node_exporter.tgz" }' /tmp/sha256sums.txt | sha256sum -c -; \
    tar -xzf /tmp/node_exporter.tgz --strip-components=1 -C /out \
        "node_exporter-${NODE_EXPORTER_VERSION}.linux-${arch}/node_exporter"; \
    chmod 0755 /out/node_exporter; \
    rm -f /tmp/node_exporter.tgz

# ---------- Stage 4: bundled process metrics plugin ----------
FROM alpine:3.20 AS process-exporter

ARG PROCESS_EXPORTER_VERSION
ARG TARGETARCH
RUN set -eux; \
    apk add --no-cache ca-certificates curl tar; \
    arch="${TARGETARCH:-$(apk --print-arch)}"; \
    case "$arch" in \
        x86_64) arch=amd64 ;; \
        aarch64) arch=arm64 ;; \
        amd64|arm64) ;; \
        *) echo "unsupported process_exporter arch: $arch" >&2; exit 1 ;; \
    esac; \
    mkdir -p /out; \
    asset="process-exporter-${PROCESS_EXPORTER_VERSION}.linux-${arch}.tar.gz"; \
    base="https://github.com/ncabatoff/process-exporter/releases/download/v${PROCESS_EXPORTER_VERSION}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/process_exporter.tgz "${base}/${asset}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/checksums.txt "${base}/checksums.txt"; \
    awk -v asset="${asset}" '$2 == asset { print $1 "  /tmp/process_exporter.tgz" }' /tmp/checksums.txt | sha256sum -c -; \
    tar -xzf /tmp/process_exporter.tgz --strip-components=1 -C /out \
        "process-exporter-${PROCESS_EXPORTER_VERSION}.linux-${arch}/process-exporter"; \
    mv /out/process-exporter /out/process_exporter; \
    chmod 0755 /out/process_exporter; \
    rm -f /tmp/process_exporter.tgz

# ---------- Stage 5: bundled traces plugin ----------
FROM alpine:3.20 AS otelcol-contrib

ARG OTELCOL_VERSION
ARG TARGETARCH
RUN set -eux; \
    apk add --no-cache ca-certificates curl tar; \
    arch="${TARGETARCH:-$(apk --print-arch)}"; \
    case "$arch" in \
        x86_64) arch=amd64 ;; \
        aarch64) arch=arm64 ;; \
        amd64|arm64) ;; \
        *) echo "unsupported otelcol-contrib arch: $arch" >&2; exit 1 ;; \
    esac; \
    mkdir -p /out; \
    asset="otelcol-contrib_${OTELCOL_VERSION}_linux_${arch}.tar.gz"; \
    base="https://github.com/open-telemetry/opentelemetry-collector-releases/releases/download/v${OTELCOL_VERSION}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/otelcol-contrib.tgz "${base}/${asset}"; \
    curl -fL --retry 3 --retry-all-errors --retry-delay 3 --connect-timeout 15 -o /tmp/checksums.txt "${base}/opentelemetry-collector-releases_otelcol-contrib_checksums.txt"; \
    awk -v asset="${asset}" '$2 == asset { print $1 "  /tmp/otelcol-contrib.tgz" }' /tmp/checksums.txt | sha256sum -c -; \
    tar -xzf /tmp/otelcol-contrib.tgz -C /out otelcol-contrib; \
    chmod 0755 /out/otelcol-contrib; \
    rm -f /tmp/otelcol-contrib.tgz

# ---------- Stage 6: runtime (distroless, nonroot) ----------
# promtail is distributed as a dynamically linked Linux binary, so the
# final image needs the base distroless runtime rather than static.
FROM gcr.io/distroless/base-debian12:nonroot

COPY --from=builder /out/ongrid-edge /ongrid-edge
COPY --from=promtail /out/promtail /usr/local/lib/ongrid-edge/promtail
COPY --from=node-exporter /out/node_exporter /usr/local/lib/ongrid-edge/node_exporter
COPY --from=process-exporter /out/process_exporter /usr/local/lib/ongrid-edge/process_exporter
COPY --from=otelcol-contrib /out/otelcol-contrib /usr/local/lib/ongrid-edge/otelcol-contrib

# Local /metrics only — edge dials cloud, no inbound service ports.
EXPOSE 9101

USER nonroot
ENTRYPOINT ["/ongrid-edge"]
