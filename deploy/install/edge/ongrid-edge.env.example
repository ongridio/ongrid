# ongrid-edge environment file - rendered by install-edge.sh to
# /mnt/data/tool-temp/etc/ongrid-edge/ongrid-edge.env. The systemd unit reads
# this via EnvironmentFile=. The ongrid-edge binary consumes these env vars
# directly (see internal/pkg/config/config.go: ONGRID_EDGE_CLOUD_ADDR /
# _ACCESS_KEY / _SECRET_KEY).

ONGRID_EDGE_CLOUD_ADDR=__CLOUD_ADDR__
ONGRID_EDGE_ACCESS_KEY=__ACCESS_KEY__
ONGRID_EDGE_SECRET_KEY=__SECRET_KEY__
ONGRID_EDGE_COLLECTOR_MODE=auto
ONGRID_EDGE_SCRAPE_CONFIG_FILE=/mnt/data/tool-temp/etc/ongrid-edge/scrape.yaml
ONGRID_EDGE_COLLECTOR_INTERVAL=10s

# ---- Plugin runtime (ADR-015) ----------------------------------------
# Edge ID is needed by every plugin to inject the `edge_id` label set on
# outbound telemetry. Empty by default — plugins refuse to render config
# until operator sets this (auto-discovered ID will land here in PR-C2).
ONGRID_EDGE_ID=

# ---- Logs plugin (ADR-012) -------------------------------------------
# Off by default. Set ENABLED=true + ENDPOINT=https://<manager>/loki/api/v1/push
# to start shipping journald + file tail logs. AUTH_USER / AUTH_PASS
# default to the tunnel ACCESS_KEY / SECRET_KEY above (data plane and
# control plane share credentials per ADR-014 §决策第 2 条).
ONGRID_EDGE_PLUGIN_LOGS_ENABLED=false
ONGRID_EDGE_PLUGIN_LOGS_ENDPOINT=
# ONGRID_EDGE_PLUGIN_LOGS_AUTH_USER=  # defaults to ONGRID_EDGE_ACCESS_KEY
# ONGRID_EDGE_PLUGIN_LOGS_AUTH_PASS=  # defaults to ONGRID_EDGE_SECRET_KEY
# Spec is JSON; control which sources are tailed.
# ONGRID_EDGE_PLUGIN_LOGS_SPEC_JSON={"file_paths":["/var/log/syslog"]}
